generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  name          String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  phoneNumber   String // Dấu ? nghĩa là được phép để trống (NULL) dưới DB
  address       String?
  status        String         @default("Active") // Mặc định là 'Active' nếu không nhập
  avatar        String?
  position      String?
  cart          Cart?
  hourlyRate    Int      @default(25000)

  workSchedules WorkSchedule[]
  notifications Notification[]
  orders        Order[]
}

enum Role {
  USER
  ADMIN
  STAFF
  MANAGER
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?  @db.Text // Dùng Text thay vì Varchar giới hạn

  // Decimal(10, 2) nghĩa là tối đa 10 chữ số, 2 số sau dấu phẩy
  price       Decimal  @default(0) @db.Decimal(10, 2)

  stock       Int      @default(0)
  thumbnail   String?

  images      String[]

  isActive    Boolean  @default(true)

  // Quan hệ với Category (nếu có)
  // category    Category? @relation(fields: [categoryId], references: [id])
  // categoryId  Int?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
  productCategoryId Int?             // Khóa ngoại
  productCategory   ProductCategory? @relation(fields: [productCategoryId], references: [id])
  soldCount   Int           @default(0)

  @@map("products") // Tên bảng trong DB
}

// schema.prisma

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int?       @unique // Có thể null nếu user chưa login (Guest)
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId]) // Một giỏ hàng chỉ chứa 1 dòng cho mỗi sản phẩm (tránh trùng lặp)
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  NOT_STARTED
  CHECKED_IN
  CHECKED_OUT
  ABSENT
}

model WorkSchedule {
  id                 Int              @id @default(autoincrement())
  userId             Int
  user               User             @relation(fields: [userId], references: [id])
  
  startTime          DateTime         
  endTime            DateTime         
  note               String?          // Ghi chú lúc đăng ký ca
  
  status             ApprovalStatus   @default(PENDING)
  isPublished        Boolean          @default(false)
  
  // 👇 ĐÃ THÊM 2 DÒNG NÀY ĐỂ FIX LỖI QUAN HỆ VỚI BẢNG ScheduleSetting 👇
  settingId          Int?
  setting            ScheduleSetting? @relation(fields: [settingId], references: [id])
  
  // 👇 ĐƯA TRẠNG THÁI VÀ GIỜ CHẤM CÔNG VÀO TRỰC TIẾP ĐÂY 👇
  attendanceStatus   String           @default("NOT_STARTED") // NOT_STARTED, CHECKED_IN, CHECKED_OUT
  actualCheckInTime  DateTime?        // Giờ bấm Vào
  actualCheckOutTime DateTime?        // Giờ bấm Ra
  checkInNote        String?          // Ghi chú lúc bấm Vào
  checkOutNote       String?          // Ghi chú lúc bấm Ra
  isAttendanceValid  Boolean          @default(true) // Máy tự đánh giá đi đúng giờ không

  // Tính lương
  payrollStatus   PayrollStatus       @default(UNCHECKED)
  standardMinutes Int                 @default(0) 
  otMinutes       Int                 @default(0) 
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  isPaid              Boolean  @default(false)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      // ID của người nhận thông báo
  title     String   // Tiêu đề: "🔔 Đã mở cổng đăng ký ca làm!"
  message   String   // Nội dung chi tiết
  isRead    Boolean  @default(false) // Trạng thái Đã đọc / Chưa đọc
  type      String   @default("SYSTEM") // Phân loại: SYSTEM, SCHEDULE...
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduleSetting {
  id             Int      @id @default(autoincrement())
  isOpen         Boolean  @default(true)
  closeTime      DateTime
  shiftStartDate DateTime
  shiftEndDate   DateTime
  
  // 1 đợt cấu hình có thể chứa nhiều ca làm được đăng ký
  workSchedules  WorkSchedule[] 
}

enum PaymentStatus {
  PENDING    // Đang chờ thanh toán
  COMPLETED  // Đã thanh toán thành công
  FAILED     // Thanh toán thất bại / Hủy
  REFUNDED   // Đã hoàn tiền
}

enum OrderStatus {
  PENDING     // Đơn hàng mới
  PROCESSING  // Đang xử lý / Đóng gói
  SHIPPED     // Đang giao hàng
  DELIVERED   // Đã giao thành công
  CANCELLED   // Đã hủy
}

enum ShippingMethod {
  DELIVERY
  TAKEAWAY
}

model Order {
  id              Int           @id @default(autoincrement())
  orderCode       String        @unique 
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  
  totalAmount     Decimal       @db.Decimal(10, 2)
  paymentMethod   String        @default("VNPAY") 
  paymentStatus   PaymentStatus @default(PENDING)
  orderStatus     OrderStatus   @default(PENDING)
  
  // 👇 CÁC TRƯỜNG THÔNG TIN KHÁCH HÀNG (Lưu ở Order)
  firstName       String        // Tên khách hàng lúc đặt
  lastName        String        // Họ khách hàng lúc đặt
  phone           String        // Số điện thoại liên hệ
  email           String?       // Email nhận hóa đơn (có thể null)
  
  // 👇 THÔNG TIN GIAO NHẬN (Lưu ở Order)
  shippingMethod  ShippingMethod @default(DELIVERY) // TAKEAWAY hoặc DELIVERY
  streetAddress   String?       // Địa chỉ (chỉ có khi chọn Delivery)
  apartment       String?       // Tầng/Căn hộ (chỉ có khi chọn Delivery)
  pickupTime      String?       // Giờ lấy nước (chỉ có khi chọn Takeaway - lưu dạng String "14:30" hoặc DateTime)
  
  note            String?       // Ghi chú của khách hàng lúc đặt (ít đá, nhiều đường...)

  items           OrderItem[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, paymentStatus])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Decimal  @db.Decimal(10, 2) // RẤT QUAN TRỌNG: Lưu lại giá của sản phẩm tại đúng thời điểm mua

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PayrollStatus {
  UNCHECKED
  AUTO_APPROVED
  NEEDS_REVIEW
  MANUALLY_APPROVED
  REJECTED
}

enum AttendanceType {
  CHECK_IN
  CHECK_OUT
}

// Bảng Danh mục nguyên vật liệu
model Category {
  id          Int        @id @default(autoincrement())
  name        String     @unique // Tên danh mục (VD: Sữa, Trái cây, Cà phê hạt...)
  description String?    // Mô tả thêm (không bắt buộc)
  
  // Quan hệ 1-N: 1 danh mục có nhiều nguyên vật liệu
  materials   Material[] 

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Bảng Nguyên vật liệu
model Material {
  id          Int      @id @default(autoincrement())
  name        String   
  code        String?  @unique 
  unit        String   
  stock       Float    @default(0) 
  minStock    Float    @default(0) 
  costPrice   Int      @default(0) 
  supplier    String?  
  isActive    Boolean  @default(true) 

  // 👇 Liên kết với bảng Category (Thay thế cho cột category String lúc trước)
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique // VD: Cà phê, Trà hoa quả, Bánh ngọt...
  description String?   
  
  // Quan hệ 1-N: 1 Danh mục chứa nhiều Sản phẩm
  products    Product[] 
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}