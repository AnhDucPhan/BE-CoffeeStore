generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  name        String?
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  phoneNumber String // Dấu ? nghĩa là được phép để trống (NULL) dưới DB
  address     String?
  status      String   @default("Active") // Mặc định là 'Active' nếu không nhập
  avatar      String?
  position    String?
  cart        Cart?

  workSchedules WorkSchedule[]
  notifications Notification[]
}

enum Role {
  USER
  ADMIN
  STAFF
  MANAGER
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String? @db.Text // Dùng Text thay vì Varchar giới hạn

  // Decimal(10, 2) nghĩa là tối đa 10 chữ số, 2 số sau dấu phẩy
  price Decimal @default(0) @db.Decimal(10, 2)

  stock     Int     @default(0)
  thumbnail String?

  images String[]

  isActive Boolean @default(true)

  // Quan hệ với Category (nếu có)
  // category    Category? @relation(fields: [categoryId], references: [id])
  // categoryId  Int?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cartItems CartItem[]

  @@map("products") // Tên bảng trong DB
}

// schema.prisma

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int?       @unique // Có thể null nếu user chưa login (Guest)
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  cart      Cart     @relation(fields: [cartId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId]) // Một giỏ hàng chỉ chứa 1 dòng cho mỗi sản phẩm (tránh trùng lặp)
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  NOT_STARTED
  CHECKED_IN
  CHECKED_OUT
  ABSENT
}

model WorkSchedule {
  id               Int              @id @default(autoincrement())
  startTime        DateTime
  endTime          DateTime
  status           ApprovalStatus   @default(PENDING) 
  isPublished      Boolean          @default(false)
  attendanceStatus AttendanceStatus @default(NOT_STARTED)
  note             String?
  userId           Int
  user             User             @relation(fields: [userId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  settingId        Int?     
  setting          ScheduleSetting? @relation(fields: [settingId], references: [id])

  // 👇 THÊM INDEX ĐỂ TỐI ƯU TỐC ĐỘ TÌM KIẾM
  @@index([startTime, endTime])
  @@index([userId, status, isPublished])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      // ID của người nhận thông báo
  title     String   // Tiêu đề: "🔔 Đã mở cổng đăng ký ca làm!"
  message   String   // Nội dung chi tiết
  isRead    Boolean  @default(false) // Trạng thái Đã đọc / Chưa đọc
  type      String   @default("SYSTEM") // Phân loại: SYSTEM, SCHEDULE...
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduleSetting {
  id             Int      @id @default(autoincrement())
  isOpen         Boolean  @default(true)
  closeTime      DateTime
  shiftStartDate DateTime
  shiftEndDate   DateTime
  
  // 1 đợt cấu hình có thể chứa nhiều ca làm được đăng ký
  workSchedules  WorkSchedule[] 
}
